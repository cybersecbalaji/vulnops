# ─────────────────────────────────────────────────────────────────────────────
# VulnOps Triage Console — Root environment template
#
# Copy to .env and fill in values. Run `python scripts/setup.py` to generate
# crypto secrets automatically. NEVER commit .env to git.
#
# This file is shared by both docker-compose.yml (dev) and
# docker-compose.prod.yml (production). The backend also reads backend/.env
# which is auto-generated by setup.py.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (docker-compose) ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Frontend → Backend routing ────────────────────────────────────────────────
# Internal URL used by the Next.js Route Handler proxy.
# In Docker Compose this is the backend service name. In Railway/Fly/Render
# this is the internal service URL (e.g. http://api.railway.internal:8000).
# The browser NEVER sees this value — all API calls go through /api/v1/ on
# the frontend origin.
BACKEND_URL=http://backend:8000

# ── Caddy (production only) ───────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Scheduler (optional) ──────────────────────────────────────────────────────
# Set to true to enable scheduled scanner sync (every 6 hours).
# Leave false if you use an external cron or prefer manual sync-now.
SCHEDULER_ENABLED=false
