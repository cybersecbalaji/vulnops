# ─────────────────────────────────────────────────────────────────────────────
# VulnOps Triage Console — Backend Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
# Use postgresql+asyncpg:// scheme for async SQLAlchemy
# Docker Compose (backend container → db service):
DATABASE_URL=postgresql+asyncpg://vulnops:changeme@db:5432/vulnops
# Local dev (running outside Docker):
# DATABASE_URL=postgresql+asyncpg://vulnops:changeme@localhost:5432/vulnops

# ── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose:
REDIS_URL=redis://redis:6379/0
# Local dev:
# REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   Then paste the PEM content here with \n for newlines, OR store as multiline.
#
# For local dev, run: python -c "from app.core.keygen import generate_and_print_keys; generate_and_print_keys()"
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_YOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_ALGORITHM=RS256

# ── Refresh Token ─────────────────────────────────────────────────────────────
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Master Encryption Key (Fernet) ───────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in a secrets manager (AWS Secrets Manager, Vault, etc.) in production.
MASTER_ENCRYPTION_KEY=PASTE_YOUR_FERNET_KEY_HERE

# ── External APIs ─────────────────────────────────────────────────────────────
NVD_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Rate Limiting ────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=10
LOCKOUT_MINUTES=15
